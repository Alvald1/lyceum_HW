const
  m = 5;
  n = 4;
  min = -10;
  max = 10;

var
  arr: array[1..m, 1..n] of integer;
  
begin
  var k := 0;  
  for var i := 1 to m do
  begin
    for var j := 1 to n do
    begin
      arr[i, j] := random(min, max);
      write(arr[i, j]:5);
    end;
    writeln;
  end;
  
  for var j := 1 to n do
  begin
    var d := arr[1, j] - arr[2, j];
    var flag := true;
    for var i := 3 to m do      
      if arr[i, j] - arr[i - 1, j] <> d then
      begin
        flag := false;
        break;
      end;    
    if flag then begin
      inc(k);
      print(j);
    end;
  end;
  if k = 0 then writeln('Нет арифметических последовательностей в столбцах')
  else writeln;
  
  k := 0;
  
  for var i := 1 to m do
  begin
    var flag := true;
    var arr2: array[min..max] of integer;
    for var j := 1 to n do
    begin
      inc(arr2[arr[i, j]]);
      if arr2[arr[i, j]] > 1 then begin
        flag := false;
        break;
      end;
    end;
    if flag then begin
      inc(k);
      print(i);
    end;
  end;
  if k = 0 then writeln('Во всех строках встречаются повторяющиеся числа')
  else writeln;
  
  k := 0;
  
  var count := -1;
  var ind := -1;
  for var j := 1 to n do
  begin
    var cur_count := 0;
    for var i := 1 to m do
    begin
      if arr[i, j] > 0 then inc(cur_count)
      else begin
        if cur_count > count then begin
          count := cur_count;
          ind := j;
        end;
        cur_count := 0;
      end;
    end;
  end;
  if ind = -1 then writeln('Нет положительных чисел')
  else print(ind);
end.
