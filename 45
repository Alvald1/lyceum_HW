program z45;

var
  s, e, count, i, max: integer;

begin
  s := -9563;
  e := -3102;
  count := 0;
  i := s;
  while i <= e do
  begin
    while i mod 7 <> 0 do i := i + 1;    
    max := i; 
    if (i mod 23 <> 0) and (i mod 10 <> -8) and (i mod 11 <> 0) then count := count + 1;    
    i := i + 7;
  end;
  write(count, ' ', max);
end.
